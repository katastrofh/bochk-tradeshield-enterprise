APP_NAME=BOC TradeShield Enterprise
ENV=local
SECRET_KEY=replace-this-with-a-long-random-secret-before-any-real-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=720
DATABASE_URL=postgresql+psycopg2://tradeshield:tradeshield@db:5432/tradeshield
CORS_ORIGINS=*
STORAGE_DIR=/app/storage

# V8 local LLM settings
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
